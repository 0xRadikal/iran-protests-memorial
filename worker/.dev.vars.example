# متغیرهای محیطیِ توسعهٔ محلی (این فایل را به .dev.vars کپی کنید)
# .dev.vars هرگز نباید commit شود.

# دامنه‌های مجاز برای CORS (با کاما جدا کنید). در توسعهٔ محلی * بگذارید.
ALLOWED_ORIGINS=*

# مدتِ اعتبارِ نشستِ ادمین (ساعت)
SESSION_TTL_HOURS=12

# کلیدِ مخفیِ Turnstile (در توسعهٔ محلی خالی بگذارید تا فرم‌ها بدونِ کپچا کار کنند).
# در محیطِ تولید با دستورِ زیر به‌صورتِ secret تنظیمش کنید:
#   npx wrangler secret put TURNSTILE_SECRET
# TURNSTILE_SECRET=
